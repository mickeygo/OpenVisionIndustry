<UserControl
    x:Class="VisionIndustry.UI.Views.StatusBarBottomContent"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:u="https://irihi.tech/ursa"
    xmlns:cc="using:VisionIndustry.UI.Controls"
    xmlns:vm="using:VisionIndustry.UI.ViewModels"
    d:DesignWidth="800"
    d:DesignHeight="450"
    x:DataType="vm:StatusBarViewModel"
    mc:Ignorable="d">
    
    <StackPanel Orientation="Horizontal"
                VerticalAlignment="Center"
                HorizontalAlignment="Right"
                Spacing="12">
        <StackPanel.Styles>
            <Style Selector="Label">
                <Setter Property="Theme" Value="{StaticResource TagLabel}" />
            </Style>
        </StackPanel.Styles>
        
        <StackPanel Orientation="Horizontal" Spacing="2">
            <Label Classes="Blue" Content="版本" />
            <Label Classes="Solid Blue" Content="{Binding Version}" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" Spacing="2">
            <Label Classes="Blue" Content="服务器" />
            <Label Classes="Solid Blue" Content="{Binding Server}" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" Spacing="4">
            <Label Classes="Blue" Content="状态" />
            <cc:Led Diameter="14" State="{Binding ServerConnectionState}" />
        </StackPanel>
    </StackPanel>
</UserControl>
