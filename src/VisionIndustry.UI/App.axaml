<Application 
    x:Class="VisionIndustry.UI.App"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:semi="https://irihi.tech/semi"
    xmlns:u="https://irihi.tech/ursa"
    xmlns:iri="https://irihi.tech/shared"
    RequestedThemeVariant="Default">
    <Application.Styles>
        <semi:SemiTheme Locale="zh-CN" />
        <semi:UrsaSemiTheme Locale="zh-CN" />
        <semi:SemiPopupAnimations />
        <StyleInclude Source="avares://Semi.Avalonia.DataGrid/Index.axaml" />

        <!--This style is created to demonstrate Dialog StyleClass feature. This style is applied to Dialog Window-->
        <Style Selector="u|StandardDialogWindow.Custom">
            <Style Selector="^ /template/ Button#PART_OKButton">
                <Setter Property="Content" Value="CUSTOM"/>
                <Setter Property="iri:ClassHelper.Classes" Value="Warning"></Setter>
            </Style>
        </Style>
        <!-- 禁用 Label 控件助记符逻辑，防止对下划线进行转义 -->
        <Style Selector="Label > ContentPresenter">
            <Setter Property="RecognizesAccessKey" Value="False" />
        </Style>
    </Application.Styles>

    <!-- 自定义资源文件 -->
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <MergeResourceInclude Source="/Accents/Index.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
