<u:UrsaWindow
    x:Class="VisionFarm.UI.Views.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:u="https://irihi.tech/ursa"
    xmlns:views="using:VisionFarm.UI.Views"
    xmlns:vm="using:VisionFarm.UI.ViewModels"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:CompileBindings="True"
    x:DataType="vm:MainWindowViewModel"
    IsFullScreenButtonVisible="{OnPlatform True,macOS=False}"
    Icon="/Assets/Icons/logo.ico"
    IsManagedResizerVisible="{OnPlatform {x:False}, Linux={x:True}}"
    mc:Ignorable="d">

    <!-- 左上角标题栏 -->
    <u:UrsaWindow.LeftContent>
        <views:TitleBarLeftContent/>
    </u:UrsaWindow.LeftContent>
    <!-- 右上角标题栏 -->
    <u:UrsaWindow.RightContent>
        <views:TitleBarRightContent/>
    </u:UrsaWindow.RightContent>
    <!-- 主界面 -->
    <views:MainView />
</u:UrsaWindow>
